# Database
DATABASE_URL="postgresql://user:Yussefm1074@localhost:5432/ai_media_platform?schema=public"

# Application
NODE_ENV="development"
PORT=3000
API_PREFIX="api/v1"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption (for OAuth tokens)
ENCRYPTION_KEY="your-32-character-encryption-key!!"
ENCRYPTION_ALGORITHM="aes-256-cbc"

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN="your-google-ads-developer-token"
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/v1/auth/google/callback"

# AI Provider (OpenAI, Anthropic, etc.)
AI_PROVIDER="openai" # openai, anthropic, azure
AI_API_KEY="your-ai-api-key"
AI_MODEL="gpt-4-turbo-preview"
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# Background Jobs
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Metrics Ingestion Schedule (cron)
METRICS_SYNC_CRON="0 */6 * * *" # Every 6 hours
TOKEN_REFRESH_CRON="0 */1 * * *" # Every hour

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN="http://localhost:3001"

# Frontend URL
FRONTEND_URL="http://localhost:3001"

# Logging
LOG_LEVEL="debug"
